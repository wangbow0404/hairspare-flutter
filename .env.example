# 이 파일은 예시입니다. 실제 값이 들어간 .env 는 절대 Git 에 커밋하지 마세요.
#
# 로컬에서 시크릿을 빌드에 넣으려면 예:
#   flutter run --dart-define=API_BASE_URL=https://api.example.com --dart-define=KAKAO_NATIVE_APP_KEY=your_key_here
#
# 또는 JSON 파일:
#   flutter run --dart-define-from-file=path/to/defines.json
#
# defines.json 예: {"API_BASE_URL":"https://...","KAKAO_NATIVE_APP_KEY":"..."}

API_BASE_URL=http://localhost:8000
USE_MOCK_DATA=false
KAKAO_NATIVE_APP_KEY=
